{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the online selling platform.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "customer"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "An item for sale.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A description of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "category": {
          "type": "string",
          "enum": ["cakes", "clothes", "household"],
          "description": "The category of the product."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "A URL to an image of the product."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the product was added."
        }
      },
      "required": ["name", "description", "price", "category", "imageUrl", "createdAt"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in a user's shopping cart.",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the product."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the product in the cart."
        },
        "price": {
          "type": "number",
          "description": "The price of the product at the time it was added."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The image URL of the product."
        }
      },
      "required": ["productId", "quantity", "price", "name", "imageUrl"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item in a user's wishlist.",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the product."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The image URL of the product."
        },
        "category": {
          "type": "string",
          "description": "The category of the product."
        },
        "description": {
          "type": "string",
          "description": "A description of the product."
        }
      },
      "required": ["productId", "name", "price", "imageUrl", "category", "description"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a product.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who wrote the review."
        },
        "userName": {
          "type": "string",
          "description": "The name of the user who wrote the review."
        },
        "rating": {
          "type": "number",
          "description": "The rating given by the user (1-5)."
        },
        "text": {
          "type": "string",
          "description": "The text of the review."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was created."
        }
      },
      "required": ["userId", "userName", "rating", "text", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the user who placed the order."
        },
        "userName": {
          "type": "string",
          "description": "The name of the user who placed the order."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "The items in the order."
        },
        "total": {
          "type": "number",
          "description": "The total price of the order."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Shipped", "Delivered", "Cancelled"],
          "description": "The status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was created."
        }
      },
      "required": ["userId", "userEmail", "userName", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores products available for sale."
    },
    "/users/{userId}/cart/{cartItemId}": {
      "schema": {
        "$ref": "#/entities/CartItem"
      },
      "description": "Stores items in a user's shopping cart."
    },
    "/users/{userId}/wishlist/{wishlistItemId}": {
      "schema": {
        "$ref": "#/entities/WishlistItem"
      },
      "description": "Stores items in a user's wishlist."
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Stores reviews for a product."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores customer orders."
    }
  }
}
